{
  "expo": {
    "name": "AIS SNAPSHOT",
    "slug": "snapshot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "snapshot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.empiredigitalsmain.snapshot",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.empiredigitalsmain.snapshot",
      "googleServicesFile": "./google-services.json",
      "versionCode": 10001,
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE", "POST_NOTIFICATIONS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "networkInspector": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#E6F4FE",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "AIS needs access to your Camera to enable scanning and uploading of documents efficiently. By allowing camera access, you can easily digitize and share your documents through the app."
        }
      ],
      [
        "expo-document-picker",
        {
          "appleTeamId": "5D86ZQ65R4"
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": ["./assets/images/logo.png"],
          "largeIcons": ["./assets/images/logo.png"]
        }
      ],
      ["@config-plugins/react-native-blob-util"],
      ["@config-plugins/react-native-pdf"],
      "./plugins/withOkHttpResolution.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78d1ffc7-73b4-4ef0-85bc-a54d19254c4c"
      },
      "oneSignalAppId": "48753398-9703-44a7-a9bb-9e1de19600b2"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/78d1ffc7-73b4-4ef0-85bc-a54d19254c4c"
    }
  }
}
